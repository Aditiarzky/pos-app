    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "node -e \"require('fs').mkdirSync('dist/server', { recursive: true }); require('fs').writeFileSync('dist/server/index.js', 'export default { async fetch() { return new Response(\\\"Building...\\\") } }')\" && vinext build",
