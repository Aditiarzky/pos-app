@startuml
|Admin Toko / Admin Sistem|
start
:Buka menu Produk;
:Pilih aksi (Tambah, Edit, atau Hapus);

if (Aksi?) then (Tambah Produk)
  :Isi nama, kategori, satuan dasar, dan varian produk;
  :Setiap varian diisi: nama, harga jual, dan konversi ke satuan terkecil;
  |Sistem POS|
  :Validasi data wajib (nama min. 3 karakter, harga jual > 0, konversi >= 1);
  if (Data Valid?) then (Ya)
    :Simpan produk dan semua variannya;
  else (Tidak)
    :Tampilkan pesan error validasi;
    stop
  endif

else if (Edit Produk)
  |Admin Toko / Admin Sistem|
  :Ubah data produk atau varian yang diinginkan;
  |Sistem POS|
  :Validasi data yang diubah;
  if (Data Valid?) then (Ya)
    :Simpan perubahan;
  else (Tidak)
    :Tampilkan pesan error;
    stop
  endif

else (Hapus Produk)
  |Admin Toko / Admin Sistem|
  :Pilih produk yang akan dihapus;
  |Sistem POS|
  :Pindahkan produk ke Trash (soft delete, bisa dipulihkan);
endif

|Sistem POS|
:Tampilkan notifikasi berhasil;
|Admin Toko / Admin Sistem|
:Lihat perubahan di daftar produk;
stop
@enduml
