@startuml
|Admin Sistem|
start
:Buka menu Trash (Sampah);
:Lihat daftar data yang sudah dihapus (soft delete);
:Pilih tindakan (Pulihkan atau Hapus Permanen);

if (Tindakan?) then (Pulihkan Data)
  :Pilih data yang ingin dipulihkan;
  |Sistem POS|
  :Hapus tanda "terhapus" dari data tersebut;
  :Data kembali aktif dan muncul di menu asalnya;
  |Admin Sistem|
  :Lihat data sudah kembali aktif;

else (Hapus Permanen / Cleanup Otomatis)
  |Sistem POS|
  :Cek data di Trash yang sudah melewati batas waktu (misal: > 30 hari);
  if (Ada data kadaluarsa?) then (Ya)
    :Hapus data tersebut secara permanen dari database;
  else (Tidak)
    :Tidak ada yang dihapus;
  endif
  |Admin Sistem|
  :Lihat ringkasan hasil cleanup;
endif
stop
@enduml
