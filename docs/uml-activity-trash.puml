@startuml
|Admin Sistem|
start
:Buka menu Sampah (Trash);
:Lihat daftar data yang telah dihapus sementara;
:Pilih tindakan (Pulihkan atau Hapus Permanen);

if (Tindakan?) then (Pulihkan Data)
  :Pilih berkas/data yang akan dikembalikan;
  |Sistem POS|
  :Aktifkan kembali status data;
  :Kembalikan data ke menu asalnya;
  |Admin Sistem|
  :Konfirmasi data kembali aktif pada daftar;

else (Hapus Permanen / Pembersihan Otomatis)
  |Sistem POS|
  :Identifikasi data yang sudah melewati batas waktu penyimpanan;
  if (Ada data kedaluwarsa?) then (Ya)
    :Hapus data dari sistem secara permanen;
  else (Tidak)
    :Tidak melakukan penghapusan;
  endif
  |Admin Sistem|
  :Terima laporan hasil pembersihan sistem;
endif
stop
@enduml
