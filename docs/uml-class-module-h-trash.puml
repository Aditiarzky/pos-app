@startuml Modul_H_Pengelolaan_Sampah_Data

' Pengaturan visual agar profesional dan fungsional
skinparam classAttributeIconSize 0
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Arial"
skinparam defaultFontSize 14
skinparam titleFontSize 20

title Pengelolaan Sampah Data

package "Domain Model: Archive Center (Trash)" {
    class TrashBin {
        - trashItemList: List<TrashEntity>
        - retentionDays: Integer = 30
        + loadTrashData(): void
        + runAutoCleanup(): Integer
        + restoreAll(): void
        + emptyTrash(): void
    }

    abstract class TrashEntity {
        # id: Integer
        # entityType: String
        # itemName: String
        # deletedAt: DateTime
        # deletedBy: Integer
        + restore(): Boolean
        + purge(): Boolean
        + isExpired(days: Integer): Boolean
    }

    class ProductTrash {
        + restore(): Boolean
        + purge(): Boolean
    }

    class SaleTrash {
        + restore(): Boolean
        + purge(): Boolean
    }

    class CustomerTrash {
        + restore(): Boolean
        + purge(): Boolean
    }

    ' Relationships
    TrashBin "1" *-- "0..*" TrashEntity : manages >
    TrashEntity <|-- ProductTrash
    TrashEntity <|-- SaleTrash
    TrashEntity <|-- CustomerTrash
}

package "External Reference" {
    class Product <<external>>
    class Sale <<external>>
    class Customer <<external>>
    class User <<external>>
}

' Catatan Fungsional
note top of TrashBin
  Pusat kendali untuk data yang dihapus sementara (Soft Delete).
  Mengatur logika pembersihan otomatis berdasarkan umur data.
end note

note right of TrashEntity
  Kelas dasar untuk semua data yang mendukung fitur soft-delete.
  Memastikan setiap entitas memiliki logika pemulihan yang konsisten.
end note

@enduml
