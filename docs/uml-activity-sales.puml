@startuml
|Admin Toko|
start
:Buka menu Penjualan / Kasir;
:Cari produk (Nama/Scan);
:Tentukan jumlah produk dan identitas pelanggan;
:Pilih metode pembayaran (Tunai / Digital / Saldo);

|Sistem POS|
:Validasi ketersediaan stok;
if (Stok Cukup?) then (Ya)
  :Hitung total transaksi;
  if (Metode Pembayaran?) then (Digital)
    :Buat tagihan pembayaran digital;
    if (Pembayaran Berhasil?) then (Ya)
      :Rekam transaksi dengan status "Lunas";
    else (Gagal/Batal)
      :Batalkan proses transaksi;
      stop
    endif
  else if (Tunai)
    :Validasi nominal pembayaran;
    if (Dana Kurang?) then (Ya)
      :Konfirmasi sisa sebagai Piutang;
    else (Cukup/Lebih)
      :Hitung nilai kembalian;
      :Opsi alokasi kembalian untuk Piutang lama;
    endif
  else (Potong Saldo)
    :Kurangi saldo resmi pelanggan;
  endif
  
  :Simpan rincian penjualan;
  :Update posisi stok produk;
  :Catat pembaharuan saldo/piutang jika ada;
  
  |Admin Toko|
  :Berikan bukti transaksi kepada pelanggan;
else (Tidak)
  |Sistem POS|
  :Berikan informasi stok tidak mencukupi;
endif
stop
@enduml
