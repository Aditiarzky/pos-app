@startuml Activity - Penjualan
|Admin Toko|
start
:Inisiasi transaksi melalui antarmuka Kasir;
:Identifikasi entitas produk dan kuantitas;
:Spesifikasi identitas pelanggan dan metode pembayaran;

|Sistem POS|
:Verifikasi integritas parameter dan validasi skema data;
if (Metode & Parameter Valid?) then (Ya)
  partition "Proses Eksekusi Transaksional" {
    :Inisiasi blok transaksi database;
    :Evaluasi ketersediaan stok fisik;
    
    if (Stok Mencukupi?) then (Ya)
      :Alokasi aset inventaris dan penyesuaian stok;
      :Persistensi rincian item dan mutasi stok;
      
      if (Penggunaan Saldo Kredit?) then (Ya)
        :Rekonsiliasi saldo kredit pelanggan;
      endif

      if (Kekurangan Nominal Pembayaran?) then (Ya)
        :Formalisasi sisa tagihan sebagai akun piutang;
      else (Cukup/Lebih)
        :Kalkulasi nilai surplus pembayaran;
        :Opsi alokasi surplus untuk pelunasan piutang historis;
      endif
      
      :Update status dan metadata transaksi (Lunas/Piutang);
      
      partition "Sinkronisasi Notifikasi Stok" {
        :Evaluasi ambang batas stok (min_stock) & histori permintaan;
        if (Stok Rendah atau Perlu Restock?) then (Ya)
          :Pemicuan notifikasi sistem (Low Stock/Restock);
        endif
      }
    else (Tidak)
      :Terminasi transaksi akibat insufisiensi stok;
      stop
    endif
  }

  if (Metode Pembayaran Digital (QRIS)?) then (Ya)
    :Generasi instruksi pembayaran eksternal;
    if (Integrasi Berhasil?) then (Ya)
      :Sinkronisasi data transaksi eksternal;
    else (Gagal)
      :Eksekusi prosedur pemulihan (Rollback) dan restorasi stok;
      :Informasi kegagalan sistem kepada operator;
      stop
    endif
  endif

  |Admin Toko|
  :Finalisasi transaksi dan distribusi bukti pembayaran;
else (Tidak)
  |Sistem POS|
  :Eskalasi pesan kesalahan validasi input;
endif
stop
@enduml
