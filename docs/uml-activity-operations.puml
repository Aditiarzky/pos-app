@startuml
|Admin Sistem|
start
:Akses menu Administrasi Operasional;
if (Pilih Aktivitas?) then (Kelola Biaya & Pajak)
  :Input/Update Biaya Operasional\n(Listrik, Gaji, Sewa, dsb);
  :Konfigurasi Parameter Pajak\n(Persentase/Nominal Tetap);
  
  |Sistem POS|
  :Validasi parameter input;
  :Simpan pembaruan ke basis data;
  :Normalisasi biaya ke periode berjalan;
else (Analisis Laporan)
  |Admin Sistem|
  :Pilih kategori laporan\n(Penjualan/Keuangan/Stok);
  :Tentukan periode waktu evaluasi;
  
  |Sistem POS|
  :Kumpulkan data transaksi & operasional;
  :Ambil parameter biaya/pajak yang aktif;
  :Hitung akumulasi pendapatan & beban;
  :Otomasi kalkulasi Laba Kotor & Laba Bersih;
  :Tampilkan visualisasi performa bisnis;
  
  |Admin Sistem|
  :Evaluasi hasil laporan pada dasbor;
  :Simpan/Unduh berkas laporan;
endif

stop
@enduml
