@startuml
|Admin Sistem|
start
:Akses Menu Manajemen Keuangan (Biaya & Laporan);

if (Pilih Aktivitas?) then (Kelola Biaya & Pajak)
  :Input/Update Biaya Operasional\n(Gaji, Listrik, Sewa, dsb);
  :Konfigurasi Parameter Pajak\n(Persentase atau Nominal Tetap);
  
  |Sistem POS|
  :Validasi data input;
  :Simpan pembaruan ke basis data;
  :Sinkronisasi biaya dengan periode berjalan;
  
else (Analisis Performa Bisnis)
  |Admin Sistem|
  :Pilih tipe laporan\n(Penjualan, Pembelian, atau Laba Rugi);
  :Tentukan filter periode waktu;
  
  |Sistem POS|
  :Kumpulkan data transaksi (Sales vs HPP);
  :Kalkulasi Laba Kotor (Revenue - HPP);
  :Ambil data Biaya Operasional & Pajak aktif;
  :Kalkulasi Laba Bersih (Laba Kotor - Biaya Ops - Pajak);
  :Generate visualisasi dan ringkasan performa;
  
  |Admin Sistem|
  :Evaluasi hasil laporan pada dasbor;
  :Cetak laporan ke format A4 (PDF);
endif

stop
@enduml
